	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents ../App_QML/qml.qrc $(DISTDIR)/
	$(COPY_FILE) --parents ../../../../Qt5.12.2/5.12.2/gcc_64/mkspecs/features/data/dummy.cpp $(DISTDIR)/
